{
    "task": [
        {
            "name": "赠送碎片",
            "default_check": true,
            "entry": "赠送碎片",
            "option": [
                "是否进行信源回收"
            ],
            "description": "<p>信源赠送:每3个任意碎片换1个9号碎片,每周上限4个</p><p>信源回收:每5个任意碎片换一个9号碎片,无上限</p><p>信源回收会保证每种碎片多于15个,如果碎片本身低于这个阈值会直接结束任务</p><p>速通周期:每周二5点后刷新2次,任务间隔24小时</p>",
            "speedrun": {
                "mode": "weekly",
                "trigger": {
                    "weekly": {
                        "weekday": [
                            2
                        ],
                        "hour_start": 5
                    },
                    "run": {
                        "count": 2,
                        "min_interval_hours": 24
                    }
                }
            },
            "group": [
                "daily"
            ]
        }
    ],
    "option": {
        "是否进行信源回收": {
            "type": "switch",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "没有待领取的碎片": {
                            "next": [
                                "进入信源回收",
                                "[JumpBack]继续_基地"
                            ]
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {}
                }
            ]
        }
    }
}
