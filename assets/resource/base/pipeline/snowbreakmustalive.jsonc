{
    "开服检测": {
        "next": [
            "开服了?",
            "确定",
            "[JumpBack]返回主菜单_action",
            "[JumpBack]关闭公告",
            "[JumpBack]关闭签到",
            "[JumpBack]点击空白处关闭",
