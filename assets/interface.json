{
  "interface_version": 2,
  "github": "https://github.com/overflow65537/MAA_SnowBreak",
  "name": "尘白禁区小助手",
  "license": "./LICENSE",
  "MFW_min_req_version": "99.99.99",
  "contact": "./CONTACT.md",
  "mirrorchyan_rid": "MAA_SnowBreak",
  "welcome": "./DISCLAIMER.md",
  "description": "基于全新架构的 尘白禁区 小助手。图像技术 + 模拟控制，解放双手！ 由 MaaFramework 强力驱动！",
  "icon": "./logo.png",
  "agent": {
    "child_exec": "python",
    "child_args": [
      "{PROJECT_DIR}/MSBAcustom/main.py"
    ],
    "embedded": true
  },
  "controller": [
    {
      "name": "Adb控制器",
      "description": "<p>仅支持安卓模拟器</p>",
      "type": "Adb"
    },
    {
      "name": "Win32-Window",
      "label": "Win32控制器-通用",
      "description": "<p>通用Win32控制器，兼容性更好，偶尔会占用鼠标</p><p>需要管理员权限</p><p>请正确填写程序路径(game.exe)以自动启动程序</p><p>参数填写：-FeatureLevelES31</p>",
      "type": "Win32",
      "win32": {
        "class_regex": "UnrealWindow",
        "window_regex": "^(尘白禁区|塵白禁域|Snowbreak[^\\w]*Containment Zone)|Game  $",
        "screencap": "Background",
        "mouse": "SendMessageWithCursorPos",
        "keyboard": "SendMessageWithCursorPos"
      },
      "permission_required": true,
      "attach_resource_path": [
        "./resource/PC"
      ]
    },
    {
      "name": "Win32-Launcher",
      "label": "桌面端登录器",
      "description": "<p>某些情况下无法通过参数直接启动游戏,需要使用桌面端登录器</p><p>需要管理员权限</p><p>请正确填写程序路径(SeasunGame.exe)以自动启动程序</p>",
      "type": "Win32",
      "win32": {
        "class_regex": "UnrealWindow",
        "window_regex": "^西山居登录器-尘白禁区$",
        "screencap": "PrintWindow",
        "mouse": "Seize",
        "keyboard": "Seize"
      },
      "permission_required": true,
      "attach_resource_path": [
        "./resource/Launcher"
      ]
    },
    {
      "name": "Win32-Window-Background",
      "label": "Win32控制器-后台",
      "description": "<p>Win32控制器-后台，完全不占用鼠标，需要游戏处于窗口模式生效</p><p>需要管理员权限</p><p>请正确填写程序路径(game.exe)以自动启动程序</p><p>参数填写：-FeatureLevelES31</p>",
      "type": "Win32",
      "win32": {
        "class_regex": "UnrealWindow",
        "window_regex": "^(尘白禁区|塵白禁域|Snowbreak[^\\w]*Containment Zone)|Game  $",
        "screencap": "PrintWindow",
        "mouse": "SendMessageWithWindowPos",
        "keyboard": "SendMessageWithWindowPos"
      },
      "permission_required": true,
      "attach_resource_path": [
        "./resource/PC"
      ]
    },
    {
      "name": "Win32-Window-Front",
      "label": "Win32控制器-前台",
      "description": "<p>Win32控制器-前台，占用鼠标，最强的兼容性</p><p>需要管理员权限</p><p>请正确填写程序路径(game.exe)以自动启动程序</p><p>参数填写：-FeatureLevelES31</p>",
      "type": "Win32",
      "win32": {
        "class_regex": "UnrealWindow",
        "window_regex": "^(尘白禁区|塵白禁域|Snowbreak[^\\w]*Containment Zone)|Game  $",
        "screencap": "PrintWindow",
        "mouse": "Seize",
        "keyboard": "Seize"
      },
      "permission_required": true,
      "attach_resource_path": [
        "./resource/PC"
      ]
    },
    {
      "name": "PlayCover控制器",
      "type": "PlayCover",
      "description": "<p style=\"color: red; font-weight: bold;\">Macos 专用,支持PlayCover</p><p>playcover无法自己启动游戏</p>",
      "playcover": {
        "uuid": "maa.playcover"
      },
      "attach_resource_path": [
        "./resource/playcover"
      ]
    }
  ],
  "resource": [
    {
      "name": "官服",
      "path": [
        "./resource/base"
      ]
    },
    {
      "name": "B服",
      "path": [
        "./resource/base",
        "./resource/bilibili"
      ],
      "controller": [
        "Adb控制器"
      ]
    },
    {
      "name": "登录器",
      "path": [
        "./resource/base",
        "./resource/Launcher"
      ],
      "controller": [
        "Win32-Launcher"
      ]
    }
  ],
  "global_option": [
    "跳过分辨率警告"
  ],
  "task": [],
  "group": [
    {
      "name": "daily",
      "label": "日常",
      "description": "关闭游戏前的日常流程（开服检测、启动、日常清体、商店、碎片等）",
      "default_expand": true
    },
    {
      "name": "Launcher",
      "label": "登录器",
      "description": "用于启动游戏的登录器",
      "default_expand": true
    },
    {
      "name": "tools",
      "label": "工具",
      "description": "关闭游戏后的辅助工具（疗愈、钓鱼、活动等循环/限时玩法）",
      "default_expand": true
    }
  ],
  "preset": [
    {
      "name": "preset_daily",
      "label": "日常",
      "task": [
        {
          "name": "启动",
          "enabled": true
        },
        {
          "name": "兑换码",
          "enabled": true
        },
        {
          "name": "赠送感知",
          "enabled": true
        },
        {
          "name": "邮件",
          "enabled": true
        },
        {
          "name": "商店",
          "enabled": true
        },
        {
          "name": "领取体力",
          "enabled": true
        },
        {
          "name": "升级枪械",
          "enabled": true
        },
        {
          "name": "精神拟境",
          "enabled": true
        },
        {
          "name": "战斗任务",
          "enabled": true
        },
        {
          "name": "刷天启碎片",
          "enabled": true,
          "option": {
            "选择人物": "时之重奏安卡希雅"
          }
        },
        {
          "name": "刷天启碎片",
          "enabled": true,
          "option": {
            "选择人物": "霄鹰茉莉安"
          }
        },
        {
          "name": "刷天启碎片",
          "enabled": true,
          "option": {
            "选择人物": "灵鉴卜卜"
          }
        },
        {
          "name": "领取奖励",
          "enabled": true
        },
        {
          "name": "新星开拓任务",
          "enabled": true
        },
        {
          "name": "赠送碎片",
          "enabled": true
        },
        {
          "name": "收取信源碎片",
          "enabled": true
        },
        {
          "name": "信源研析",
          "enabled": true
        },
        {
          "name": "关闭游戏",
          "enabled": true
        }
      ]
    },
    {
      "name": "preset_launcher",
      "label": "登录器",
      "description": "用于启动游戏的登录器",
      "task": [
        {
          "name": "登录器",
          "enabled": true
        }
      ]
    },
    {
      "name": "preset_tools",
      "label": "工具",
      "description": "关闭游戏后使用；默认全部关闭",
      "task": [
        {
          "name": "开服检测",
          "enabled": false
        },
        {
          "name": "疗愈",
          "enabled": false
        },
        {
          "name": "钓鱼",
          "enabled": false
        },
        {
          "name": "猜心对局",
          "enabled": false
        },
        {
          "name": "心动水弹",
          "enabled": false
        },
        {
          "name": "妮塔之邀",
          "enabled": false
        },
        {
          "name": "限时活动-异星守护",
          "enabled": false
        },
        {
          "name": "限时活动-增益试炼",
          "enabled": false
        },
        {
          "name": "限时活动-蜃梦笔谈",
          "enabled": false
        }
      ]
    }
  ],
  "import": [
    "./tasks/开服检测.json",
    "./tasks/登录器.json",
    "./tasks/启动.json",
    "./tasks/兑换码.json",
    "./tasks/赠送感知.json",
    "./tasks/邮件.json",
    "./tasks/商店.json",
    "./tasks/领取体力.json",
    "./tasks/升级枪械.json",
    "./tasks/精神拟境.json",
    "./tasks/战斗任务.json",
    "./tasks/刷天启碎片.json",
    "./tasks/领取奖励.json",
    "./tasks/新星开拓任务.json",
    "./tasks/收取信源碎片.json",
    "./tasks/赠送碎片.json",
    "./tasks/信源研析.json",
    "./tasks/关闭游戏.json",
    "./tasks/疗愈.json",
    "./tasks/钓鱼.json",
    "./tasks/猜心对局.json",
    "./tasks/心动水弹.json",
    "./tasks/妮塔之邀.json",
    "./tasks/限时活动-异星守护.json",
    "./tasks/限时活动-增益试炼.json",
    "./tasks/限时活动-蜃梦笔谈.json",
    "./tasks/选项_选择章节.json"
  ],
  "option": {
    "跳过分辨率警告": {
      "label": "是否跳过分辨率警报",
      "description": "打开后将跳过分辨率不符的警告提示",
      "type": "switch",
      "default_case": "No",
      "cases": [
        {
          "name": "Yes",
          "pipeline_override": {
            "检查分辨率": {
              "enabled": false
            }
          }
        },
        {
          "name": "No",
          "pipeline_override": {
            "检查分辨率": {
              "enabled": true
            }
          }
        }
      ]
    }
  },
  "version": "v3.1.14"
}